# .env.example — copy to .env and fill in real values
# .env is gitignored — NEVER commit real credentials

# Jenkins admin password
JENKINS_ADMIN_PASSWORD=admin123

# Azure credentials (from create-service-principal.sh output)
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Dev Service Principal
AZURE_SP_DEV_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_SP_DEV_CLIENT_SECRET=your-dev-sp-secret

# Staging Service Principal
AZURE_SP_STAGING_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_SP_STAGING_CLIENT_SECRET=your-staging-sp-secret

# Prod Service Principal
AZURE_SP_PROD_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_SP_PROD_CLIENT_SECRET=your-prod-sp-secret

# Terraform sensitive variables
TF_VAR_sql_admin_login=sqladmin
TF_VAR_sql_admin_password=MyStr0ngP@ssw0rd!
TF_VAR_ssh_public_key=ssh-rsa AAAAB3Nza...your-public-key
