###############################################################################
# versions.tf — pin provider versions for reproducible deployments
# Always pin to a minor version range (~>) never exact patch so security
# fixes are picked up automatically, but breaking changes are not.
###############################################################################
terraform {
  required_version = ">= 1.6.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 3.110"
    }
    azuread = {
      source  = "hashicorp/azuread"
      version = "~> 2.47"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }
}
